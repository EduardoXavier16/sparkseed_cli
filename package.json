{
  "name": "sparkseed",
  "version": "1.0.0",
  "description": "Interactive CLI that generates complete project boilerplates with PRD, Design System and architecture",
  "main": "dist/index.js",
  "bin": {
    "sparkseed": "./dist/index.js"
  },
  "scripts": {
    "start": "node dist/index.js",
    "build": "tsc",
    "dev": "ts-node src/index.ts",
    "test": "vitest",
    "lint": "biome lint .",
    "lint:eslint": "eslint src --ext .ts --report-unused-disable-directives --max-warnings 0",
    "lint:eslint:fix": "eslint src --ext .ts --fix",
    "format": "biome format .",
    "format:prettier": "prettier --write \"src/**/*.{ts,js,json,md}\""
  },
  "keywords": [
    "cli",
    "boilerplate",
    "generator",
    "prd",
    "design-system"
  ],
  "author": "",
  "license": "MIT",
  "dependencies": {
    "chalk": "^4.1.2",
    "commander": "^11.1.0",
    "inquirer": "^8.2.6",
    "ora": "^5.4.1"
  },
  "devDependencies": {
    "@biomejs/biome": "^1.8.0",
    "@types/inquirer": "^8.2.10",
    "@types/node": "^20.10.0",
    "@typescript-eslint/eslint-plugin": "^8.56.1",
    "@typescript-eslint/parser": "^8.56.1",
    "eslint": "^8.56.0",
    "prettier": "^3.2.0",
    "ts-node": "^10.9.2",
    "typescript": "^5.3.0",
    "vitest": "^4.0.18"
  }
}
